{
  "name": "@vibeahack/mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Vibeahack MCP server — belief search, budget routing, and quotes exposed to MCP clients over stdio",
  "bin": {
    "vibeahack-mcp": "dist/main.js"
  },
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vibeahack/shared": "*"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
